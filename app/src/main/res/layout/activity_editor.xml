<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="@string/app_name" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button
            android:id="@+id/prevPageButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/page_prev" />

        <TextView
            android:id="@+id/pageLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="16sp" />

        <Button
            android:id="@+id/nextPageButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/page_next" />

        <Button
            android:id="@+id/addPageButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/page_add" />

        <ImageButton
            android:id="@+id/pageSettingsButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/page_settings_title"
            android:src="@android:drawable/ic_menu_manage" />

    </LinearLayout>

    <!-- Fixed to @dimen/keyboard_height (defined in :keyboard-engine, shared with
         GeneratedKeyboardService) rather than filling the remaining screen space, so the
         preview's aspect ratio matches the actual generated keyboard's instead of stretching
         taller/shorter depending on how much vertical space this Activity happens to have. -->
    <android.keyboard.engine.KeyboardGridView
        android:id="@+id/gridView"
        android:layout_width="match_parent"
        android:layout_height="@dimen/keyboard_height" />

</LinearLayout>
